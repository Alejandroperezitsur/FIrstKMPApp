<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    <!-- Outer Circle -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#1976D2"
        android:strokeWidth="4"
        android:pathData="M 50,50 m -48,0 a 48,48 0 1,0 96,0 a 48,48 0 1,0 -96,0" />
    <!-- Inner Decoration -->
    <path
        android:strokeColor="#D3E3FD"
        android:strokeWidth="2"
        android:pathData="M 50,50 m -40,0 a 40,40 0 1,0 80,0 a 40,40 0 1,0 -80,0" />
    <!-- Hour Markers -->
    <path
        android:strokeColor="#1976D2"
        android:strokeWidth="4"
        android:pathData="M50 10 L50 20 M50 90 L50 80 M10 50 L20 50 M90 50 L80 50" />
    <!-- Hour Hand -->
    <path
        android:strokeColor="#535E70"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M50 50 L75 50" />
    <!-- Minute Hand -->
    <path
        android:strokeColor="#1976D2"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M50 50 L50 25" />
    <!-- Center Point -->
    <path
        android:fillColor="#1976D2"
        android:pathData="M 50,50 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0" />
</vector>